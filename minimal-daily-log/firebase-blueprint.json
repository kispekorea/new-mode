{
  "entities": {
    "BodyStateRecord": {
      "title": "Body State Record",
      "description": "Daily body state record",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "weight": { "type": "string", "nullable": true },
        "rhythm": { "type": "string", "nullable": true },
        "walk": { "type": "string", "nullable": true },
        "muscle": { "type": "string", "nullable": true },
        "bodyCheck": { "type": "string", "nullable": true },
        "sleep": { "type": "string", "nullable": true },
        "memo": { "type": "string" },
        "imageUrl": { "type": "string", "nullable": true },
        "moodEmoji": { "type": "string", "nullable": true },
        "userId": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["date", "memo", "userId", "createdAt", "updatedAt"]
    },
    "WishlistItem": {
      "title": "Wishlist Item",
      "description": "User wishlist or expense item",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "necessity": { "type": "string" },
        "price": { "type": "string" },
        "linkUrl": { "type": "string", "nullable": true },
        "imageUrl": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["date", "name", "type", "status", "necessity", "price", "imageUrl", "userId", "createdAt", "updatedAt"]
    },
    "AILogItem": {
      "title": "AI Log Item",
      "description": "Log entry for AI usage",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "toolName": { "type": "string" },
        "usage": { "type": "string" },
        "feedback": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["date", "toolName", "usage", "feedback", "userId", "createdAt", "updatedAt"]
    },
    "FocusItem": {
      "title": "Focus Item",
      "description": "Daily focus goal",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "goal": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["date", "goal", "userId", "createdAt", "updatedAt"]
    },
    "FocusReflection": {
      "title": "Focus Reflection",
      "description": "Reflection on weekly/monthly focus",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["content", "userId", "createdAt", "updatedAt"]
    },
    "MemoItem": {
      "title": "Memo Item",
      "description": "Daily memos",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string", "nullable": true },
        "audioUrl": { "type": "string", "nullable": true },
        "userId": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["date", "title", "content", "userId", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}/bodyRecords/{recordId}": {
      "schema": { "$ref": "#/entities/BodyStateRecord" },
      "description": "Body state daily records"
    },
    "users/{userId}/wishlistItems/{itemId}": {
      "schema": { "$ref": "#/entities/WishlistItem" },
      "description": "Wishlist and expense data"
    },
    "users/{userId}/aiLogs/{logId}": {
      "schema": { "$ref": "#/entities/AILogItem" },
      "description": "AI Usage log data"
    },
    "users/{userId}/focusItems/{itemId}": {
      "schema": { "$ref": "#/entities/FocusItem" },
      "description": "Focus tracking items"
    },
    "users/{userId}/focusReflections/{reflectionId}": {
      "schema": { "$ref": "#/entities/FocusReflection" },
      "description": "Reflections for focus"
    },
    "users/{userId}/memos/{memoId}": {
      "schema": { "$ref": "#/entities/MemoItem" },
      "description": "Memo applet records"
    }
  }
}
